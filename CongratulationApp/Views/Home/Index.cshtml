@{
    IEnumerable<ContactEntity>? contactEntities = ViewBag.Contacts;
    DateOnly currentDate = DateOnly.FromDateTime(DateTime.Today);
    List<ContactEntity> atTheSameDate = new List<ContactEntity>();
}
<!-- Main -->
<div id="main">
    <!-- Current birthday -->
    <article id="home" class="panel intro">
        <header>
            <h1>
                @{
                    var nearest = contactEntities.Any() ? contactEntities.Select(c => new
                    {
                        Contact = c,
                        NextBirthday = GetNextBirthday(c.Birthday, currentDate),
                        DaysUntil = DaysUntilBirthday(c.Birthday, currentDate)
                    })
            .OrderBy(x => x.DaysUntil)
            .First() : null;
                    DateOnly GetNextBirthday(DateOnly birthday, DateOnly today)
                    {
                        DateOnly thisYearBirthday = new DateOnly(today.Year, birthday.Month, birthday.Day);
                        return thisYearBirthday < today
                                              ? new DateOnly(today.Year + 1, birthday.Month, birthday.Day)
                                              : thisYearBirthday;
                    }

                    int DaysUntilBirthday(DateOnly birthday, DateOnly today)
                    {
                        DateOnly next = GetNextBirthday(birthday, today);
                        return next.DayNumber - today.DayNumber;
                    }
                }
                @(nearest != null ? nearest!.Contact.Name : "Nothing")
            </h1>
            <p>Happy birthday incoming!</p>
            <p>Days remeins:</p>
            <p>@(nearest != null ? nearest!.DaysUntil : "Nothing")</p>
            @{
                if (nearest != null)
                {
                    foreach (ContactEntity entity in contactEntities)
                    {
                        if (entity.Birthday == nearest!.Contact.Birthday && (entity != nearest.Contact))
                        {
                            atTheSameDate.Add(entity);
                        }
                    }
                }
            }
            <p>
                @(
                    atTheSameDate.Any() ? "Also:" : "Don`t forget!"
                )
            </p>
            <div>
                <h2>
                    @foreach (ContactEntity same in atTheSameDate)
                    {
                        <span>@same.Name</span>
                    }
                </h2>
            </div>
        </header>
        <a href="#work" class="jumplink pic">
            <img src="~/img/@(nearest != null ? nearest!.Contact.Photo : "")" alt="" />
        </a>
    </article>

    <!-- All contacts -->
    <article id="work" class="panel">
        <header>
            <h2>All Birthdays</h2>
            @await Html.PartialAsync("Contacts_Index.cshtml")
        </header>
    </article>

    <!-- Add new contact -->
    <article id="contact" class="panel">
        <header>
            <h2>Add new birthday</h2>
        </header>
        <form asp-area="" asp-controller="Home" asp-action="ContactsEdit" method="post" enctype="multipart/form-data">
            <div class="row">
                <div class="col-6 col-12-medium">
                    <input type="text" name="name" placeholder="Name" />
                </div>
                <div class="col-6 col-12-medium">
                    <input type="text" name="email" placeholder="Email" />
                </div>
                <div class="col-12">
                    <input type="date" name="birthday" placeholder="Birthday date" />
                </div>
                <div class="col-12">
                    <input type="text" name="phone" placeholder="Phone number" />
                </div>
                <div class="col-12">
                    <div>
                        <label for="Image">Image:</label>
                        <input type="file" name="image" accept="image/*" />
                    </div>
                </div>
                <div class="col-12">
                    <input type="submit" value="Add" />
                </div>
                <div asp-validation-summary="All"></div>
            </div>
        </form>
    </article>
</div>